rules_version = '2';

// Famoria Firestore security rules.
//
// To deploy: from this directory run `firebase deploy --only firestore:rules`
// (or paste this file into Firebase Console → Firestore → Rules).
//
// Strategy:
//   - Authenticated users can read/write resources tied to themselves.
//   - Family-scoped collections require the user be a member of that family.
//   - Notifications can only be read by their addressee, but any authenticated
//     family member can write notifications (so the client-side notify helpers
//     in AppState can fan out).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMemberOfFamily(familyId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    // Users — a user can read/write their own user document.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSelf(userId);
    }

    // ------------------------------------------------------------
    // Subscription helpers
    // ------------------------------------------------------------

    // Only the field-level subscription writer (the family billing owner)
    // may set subscription/* fields on the family doc. We let any family
    // member touch the rest of the document (name, members denormals,
    // storageUsedBytes) but lock subscription state to the owner uid.
    function isSubscriptionOwner(familyId) {
      return isSignedIn() &&
             get(/databases/$(database)/documents/families/$(familyId))
               .data.subscriptionOwnerUID == request.auth.uid;
    }

    // Detects whether the incoming write touches any subscription field.
    function touchesSubscription() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['subscriptionTier','subscriptionStatus','subscriptionExpiration',
                 'subscriptionOwnerUID','subscriptionProductID','subscriptionInTrial',
                 'subscriptionUpdatedAt','storageLimit']);
    }

    // Families.
    match /families/{familyId} {
      allow read: if isMemberOfFamily(familyId);
      // Creating a family is allowed for any authenticated user; updates
      // require membership.
      allow create: if isSignedIn();
      // Updates: any family member can edit non-subscription fields.
      // Subscription fields are owner-only. The very first owner write
      // (when subscriptionOwnerUID is not yet set) is allowed for any
      // signed-in member of the family.
      allow update: if isMemberOfFamily(familyId) &&
                       (!touchesSubscription() ||
                        !('subscriptionOwnerUID' in resource.data) ||
                        request.auth.uid == resource.data.subscriptionOwnerUID);
      allow delete: if isMemberOfFamily(familyId);

      match /members/{memberId} {
        allow read: if isMemberOfFamily(familyId) || isSelf(memberId);
        allow write: if isSignedIn();
      }

      match /treeMembers/{memberId} {
        allow read, write: if isMemberOfFamily(familyId);
      }

      match /relationships/{relId} {
        allow read, write: if isMemberOfFamily(familyId);
      }

      // Posts, events, etc. nested under family
      match /{document=**} {
        allow read, write: if isMemberOfFamily(familyId);
      }
    }

    // Invite codes — anyone signed in can look up to redeem; only family
    // members can write.
    match /invite_codes/{code} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Legacy invites collection (used by FirebaseFamilyService alongside invite_codes).
    match /invites/{inviteId} {
      allow read, write: if isSignedIn();
    }

    // Notifications — fan-out write model. Any signed-in user can write
    // a notification doc (the client encodes the recipient as userId), but
    // only the recipient can read or update their own notifications.
    match /famoria_notifications/{notifId} {
      allow read, update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
        request.resource.data.userId is string;
    }

    // Albums + photos.
    match /famoria_albums/{albumId} {
      allow read, write: if isSignedIn();
    }
    match /famoria_photos/{photoId} {
      allow read, write: if isSignedIn();
    }

    // Documents (Document Vault). Privacy is enforced server-side by
    // checking the `privacyLevel` and `sharedWith` fields against the
    // requester. Owners always retain full access.
    match /famoria_documents/{docId} {
      function docData() {
        return resource.data;
      }
      function isOwnerOfDoc() {
        return isSignedIn() && docData().ownerUID == request.auth.uid;
      }
      function isAdminOfDocFamily() {
        return isSignedIn() &&
               docData().familyId is string &&
               exists(/databases/$(database)/documents/families/$(docData().familyId)/members/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/families/$(docData().familyId)/members/$(request.auth.uid)).data.role in ['owner','admin'];
      }
      function isFamilyMemberOfDoc() {
        return isSignedIn() &&
               docData().familyId is string &&
               exists(/databases/$(database)/documents/families/$(docData().familyId)/members/$(request.auth.uid));
      }
      allow read: if isOwnerOfDoc() ||
                     (docData().privacyLevel == 'familyVisible' && isFamilyMemberOfDoc()) ||
                     (docData().privacyLevel == 'adminOnly' && isAdminOfDocFamily()) ||
                     (docData().privacyLevel == 'sharedWithSelectedMembers' &&
                      (docData().sharedWith is list) &&
                      request.auth.uid in docData().sharedWith);
      allow create: if isSignedIn() &&
                       request.resource.data.ownerUID == request.auth.uid;
      allow update: if isOwnerOfDoc();
      allow delete: if isOwnerOfDoc() || isAdminOfDocFamily();
    }
    // Document comments — the app writes to `famoria_doc_comments`.
    // `famoria_document_comments` is kept for any legacy/backfilled data.
    match /famoria_doc_comments/{commentId} {
      allow read, write: if isSignedIn();
    }
    match /famoria_document_comments/{commentId} {
      allow read, write: if isSignedIn();
    }

    // Journal entries (Family Journal feature).
    match /famoria_journal_entries/{entryId} {
      allow read, write: if isSignedIn();
    }

    // Recipes.
    match /famoria_recipes/{recipeId} {
      allow read, write: if isSignedIn();
    }

    // Family health records.
    match /famoria_health_records/{recordId} {
      allow read, write: if isSignedIn();
    }

    // Per-user personal tasks.
    match /famoria_user_tasks/{userId} {
      allow read, write: if isSelf(userId);

      match /tasks/{taskId} {
        allow read, write: if isSelf(userId);
      }
    }

    // Chats + messages.
    match /chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // Wishlist.
    match /famoria_wishlist/{itemId} {
      allow read, write: if isSignedIn();
    }

    // Celebrations.
    match /famoria_celebrations/{celebrationId} {
      allow read, write: if isSignedIn();
    }
  }
}
